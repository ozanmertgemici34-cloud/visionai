SERVER_NAME=Friday
DEBUG=false

# LiveKit
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# Provider selection
STT_PROVIDER=faster_whisper   # faster_whisper (offline) | openai (cloud Whisper API)
LLM_PROVIDER=ollama            # ollama (local, free) | openai (cloud, paid)
TTS_PROVIDER=edge              # edge (Microsoft Neural, internet) | pyttsx3 (offline)
FRIDAY_PROFILE=ethanplus       # friday | ethanplus (ethanplus-style Jarvis tone on Windows)
FRIDAY_UI_MODE=lite            # lite | full (lite = lower GPU/CPU UI load)
FRIDAY_AUTO_WAKE_WORD=0        # 1 yaparsan startup'ta wake word otomatik açılır
FRIDAY_STATUS_POLL_MS=5000

# ---------------------------------------------------------------------------
# Ollama — tamamen ücretsiz, local
# ---------------------------------------------------------------------------
# Intent sınıflandırma için hızlı küçük model (3b çok daha hızlı)
# Kurulum: ollama pull qwen2.5:3b
OLLAMA_INTENT_MODEL=qwen2.5:3b
# Genel sohbet / ask_local_model için daha büyük model
OLLAMA_MODEL=qwen2.5:3b
OLLAMA_CODER_MODEL=qwen2.5-coder:14b-instruct-q4_K_M
OLLAMA_BASE_URL=http://127.0.0.1:11434/v1
OLLAMA_API_KEY=ollama

# ---------------------------------------------------------------------------
# OpenAI — sadece "güncel bilgi" sorularında kullanılır (isteğe bağlı)
# Haber, borsa, kur, "kim, nerede, ne zaman" gibi sorular için
# Boş bırakılırsa sistem Ollama + ddgs web araması ile devam eder (ücretsiz)
# ---------------------------------------------------------------------------

# ---------------------------------------------------------------------------
# STT Ayarları
# ---------------------------------------------------------------------------
# faster-whisper model boyutu: tiny (75MB) | base (145MB) | small (461MB) | medium (1.5GB)
FRIDAY_WHISPER_MODEL=base
# faster-whisper compute device: cpu | cuda (NVIDIA GPU varsa)
FRIDAY_WHISPER_DEVICE=cpu
FRIDAY_WHISPER_BEAM_SIZE=2
FRIDAY_STT_MAX_SPEECH_SEC=6.5

# Mikrofon hassasiyet eşiği (RMS) — düşük = daha hassas, gürültüde artır
FRIDAY_STT_SILENCE_RMS=0.010
FRIDAY_STT_RMS=0.012

# Barge-in (lafı kesme) hassasiyeti — düşür = daha kolay lafı kes
FRIDAY_BARGE_RMS=0.025
FRIDAY_BARGE_GRACE=0.2
FRIDAY_BARGE_SUSTAIN=1

# ---------------------------------------------------------------------------
# TTS Ayarları
# ---------------------------------------------------------------------------
FRIDAY_TTS_VOICE=tr-TR-AhmetNeural    # edge-tts ses: AhmetNeural (erkek) | EmelNeural (kadın)
FRIDAY_TTS_RATE=+6%
FRIDAY_TTS_PITCH=+0Hz
FRIDAY_TTS_VOLUME=+0%

# Ollama yavaşsa direkt OpenAI'ye geç (1=aktif, 0=kapalı) — OpenAI key gerekir
FRIDAY_FAST_MODE=0
# OpenAI — isteğe bağlı (güncel sorular + Fish Audio TTS için)
OPENAI_TTS_MODEL=tts-1
OPENAI_TTS_VOICE=nova
TTS_SPEED=1.1

# Optional Sarvam
SARVAM_API_KEY=
SARVAM_TTS_LANGUAGE=en-IN
SARVAM_TTS_SPEAKER=rahul

# API keys
OPENAI_API_KEY=
GOOGLE_API_KEY=
GEMINI_API_KEY=
GROQ_API_KEY=

# MCP
MCP_SERVER_PORT=8010
