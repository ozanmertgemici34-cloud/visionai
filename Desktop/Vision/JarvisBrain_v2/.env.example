SERVER_NAME=Friday
DEBUG=false

# LiveKit
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# Provider selection
STT_PROVIDER=faster_whisper   # faster_whisper (offline) | openai (cloud Whisper API)
LLM_PROVIDER=ollama            # ollama (local, free) | openai (cloud, paid)
TTS_PROVIDER=edge              # edge (Microsoft Neural, internet) | pyttsx3 (offline)
FRIDAY_PROFILE=ethanplus       # friday | ethanplus (ethanplus-style Jarvis tone on Windows)
FRIDAY_UI_MODE=lite            # lite | full (lite = lower GPU/CPU UI load)
FRIDAY_AUTO_WAKE_WORD=0        # Set to 1 to enable wake word on startup
FRIDAY_STATUS_POLL_MS=5000

# ---------------------------------------------------------------------------
# Ollama — completely free, local
# ---------------------------------------------------------------------------
# Intent classification model (3b is faster)
# Setup: ollama pull qwen2.5:3b
OLLAMA_INTENT_MODEL=qwen2.5:3b
# General chat / ask_local_model
OLLAMA_MODEL=qwen2.5:3b
OLLAMA_CODER_MODEL=qwen2.5-coder:14b-instruct-q4_K_M
OLLAMA_BASE_URL=http://127.0.0.1:11434/v1
OLLAMA_API_KEY=ollama

# ---------------------------------------------------------------------------
# OpenAI — only used for "current events" questions (optional)
# News, stocks, exchange rates, "who, where, when" type questions
# If left empty, system uses Ollama + ddgs web search (free)
# ---------------------------------------------------------------------------

# ---------------------------------------------------------------------------
# STT Settings
# ---------------------------------------------------------------------------
# faster-whisper model size: tiny (75MB) | base (145MB) | small (461MB) | medium (1.5GB)
FRIDAY_WHISPER_MODEL=base
# faster-whisper compute device: cpu | cuda (if NVIDIA GPU available)
FRIDAY_WHISPER_DEVICE=cpu
FRIDAY_WHISPER_BEAM_SIZE=2
FRIDAY_STT_MAX_SPEECH_SEC=6.5

# Microphone sensitivity threshold (RMS) — lower = more sensitive, increase in noisy environments
FRIDAY_STT_SILENCE_RMS=0.010
FRIDAY_STT_RMS=0.012

# Barge-in sensitivity — lower = easier to interrupt
FRIDAY_BARGE_RMS=0.025
FRIDAY_BARGE_GRACE=0.2
FRIDAY_BARGE_SUSTAIN=1

# ---------------------------------------------------------------------------
# TTS Settings
# ---------------------------------------------------------------------------
FRIDAY_TTS_VOICE=tr-TR-AhmetNeural    # edge-tts voice: AhmetNeural (male) | EmelNeural (female)
FRIDAY_TTS_RATE=+6%
FRIDAY_TTS_PITCH=+0Hz
FRIDAY_TTS_VOLUME=+0%

# Switch to OpenAI if Ollama is slow (1=enabled, 0=disabled) — requires OpenAI key
FRIDAY_FAST_MODE=0
# OpenAI — optional (current events + Fish Audio TTS)
OPENAI_TTS_MODEL=tts-1
OPENAI_TTS_VOICE=nova
TTS_SPEED=1.1

# Optional Sarvam
SARVAM_API_KEY=
SARVAM_TTS_LANGUAGE=en-IN
SARVAM_TTS_SPEAKER=rahul

# API keys
OPENAI_API_KEY=
GOOGLE_API_KEY=
GEMINI_API_KEY=
GROQ_API_KEY=

# MCP
MCP_SERVER_PORT=8010

# ---------------------------------------------------------------------------
# Optional safe local text routing (default: off)
# ---------------------------------------------------------------------------
# off         -> current system is used as-is
# shadow      -> current system responds, local only logs in background
# auto        -> simple text commands try local first, fallback on error
# force_local -> all text commands try local first, fallback on error
FRIDAY_LOCAL_MODE=off

# OpenAI-compatible local endpoint:
# - llama.cpp llama-server: http://127.0.0.1:8080/v1
# - llama-cpp-python server: http://127.0.0.1:8000/v1
# - Ollama OpenAI compatibility: http://127.0.0.1:11434/v1
FRIDAY_LOCAL_BASE_URL=http://127.0.0.1:8080/v1
FRIDAY_LOCAL_API_KEY=local
FRIDAY_LOCAL_MODEL=
FRIDAY_LOCAL_TIMEOUT_SEC=12
FRIDAY_LOCAL_KEEPALIVE_ENABLE=0
FRIDAY_LOCAL_KEEPALIVE=30m
FRIDAY_LOCAL_KEEPALIVE_INTERVAL_SEC=600
FRIDAY_DISABLE_LIVE_AUTO=0
# Safe example default: the checked-in .env in the TestingJarvis copy may use local voice for experiments.
FRIDAY_VOICE_BACKEND=cloud

# ---------------------------------------------------------------------------
# Telegram Bot — Access FRIDAY via Telegram
# ---------------------------------------------------------------------------
# Get token from BotFather: https://t.me/BotFather
# Add token to .env after getting it
TELEGRAM_BOT_TOKEN=

# Telegram User Session — for sending files (requires user account)
# Get from my.telegram.org
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_PHONE=